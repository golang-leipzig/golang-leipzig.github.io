current_node: Any = stack.pop()                                        \u001b[23;81H                                                                               \u001b[24;81H        if current_node not in visited:                                        \u001b[25;81H            # 1. Process the node (e.g., print it, add it to results)          \u001b[26;81H            visited.add(current_node)                                          \u001b[27;81H                                                                               \u001b[28;81H            # 2. Add unvisited neighbors to the stack.                         \u001b[29;81H            # Since we pop the stack, adding neighbors in reverse order        \u001b[30;81H            # (or processing the adjacency list in reverse) ensures that       \u001b[31;81H            # the neighbors are processed in the natural order defined by      \u001b[32;81Hthe graph's list.                                                              \u001b[33;81H            # This makes the traversal deterministic when the neighbors        \u001b[34;81Hlist order matters.                                                            \u001b[35;81H            neighbors = graph.get(current_node, [])                            \u001b[36;81H                                                                               \u001b[37;81H            # Iterate in reverse to maintain canonical traversal order         \u001b[38;81H(e.g., A -> B -> C)                                                            \u001b[39;81H            for neighbor in reversed(neighbors):                               \u001b[40;81H                if neighbor not in visited:                                    \u001b[41;81H                    stack.append(neighbor)                                     \u001b[42;81H                                                                               \u001b[43;81H    return visited                                                             \u001b[44;81H                                                                               \u001b[45;81H# --- Example Usage ---                                                        \u001b[46;81Hif __name__ == '__main__':                                                     \u001b[47;81H    # Example 1: Simple Graph (Adjacency List)                          "]
