[0.047, "o", "\u001b[?25l\u001b[1;81H```python                                                                      \u001b[2;81Hfrom typing import Dict, List, Any, Set, Callable, Tuple                       \u001b[3;81H                                                                               \u001b[4;81Hdef depth_first_search(graph: Dict[Any, List[Any]], start_node: Any) ->        \u001b[5;81HSet[Any]:                                                                      \u001b[6;81H    \"\"\"                                                                        \u001b[7;81H    Performs a Depth-First Search (DFS) traversal starting from a              \u001b[8;81Hspecified node.                                                                \u001b[9;81H                                                                               \u001b[10;81H    This implementation utilizes an explicit stack for iterative               \u001b[11;81Htraversal,                                                                     \u001b[12;81H    which is generally preferred over deep recursion for production code       \u001b[13;81H    to prevent potential StackOverflowErrors on large graphs.                  \u001b[14;81H                                                                               \u001b[15;81H    Args:                                                                      \u001b[16;81H        graph: A dictionary representing the graph, where keys are nodes       \u001b[17;81H               and values are lists of neighbors (adjacency list).             \u001b[18;81H        start_node: The node from which the traversal begins.                  \u001b[19;81H                                                                               \u001b[20;81H    Returns:                                                                   \u001b[21;81H        A set containing all unique nodes visited during the traversal.        \u001b[22;81H                                                                               \u001b[23;81H    Raises:                                                                    \u001b[24;81H        ValueError: If the start_node is not present in the graph.             \u001b[25;81H    \"\"\"                                                                        \u001b[26;81H    if start_node not in graph:                                                \u001b[27;81H        raise ValueError(f\"Start node '{start_node}' is not part of the        \u001b[28;81Hprovided graph.\")                                                              \u001b[29;81H                                                                               \u001b[30;81H    # Set to track visited nodes ensures O(1) lookup time and prevents         \u001b[31;81Hcycles from infinite loops.                                                    \u001b[32;81H    visited: Set[Any] = set()                                                  \u001b[33;81H                                                                               \u001b[34;81H    # Stack for iterative DFS traversal. Initialized with the start node.      \u001b[35;81H    stack: List[Any] = [start_node]                                            \u001b[36;81H                                                                               \u001b[37;81H    while stack:                                                               \u001b[38;81H        # Pop the current node to process                                      \u001b[39;81H        current_node: Any = stack.pop()                                        \u001b[40;81H                                                                               \u001b[41;81H        if current_node not in visited:                                        \u001b[42;81H            # 1. Process the node (e.g., print it, add it to results)          \u001b[43;81H            visited.add(current_node)                                          \u001b[44;81H                                                                               \u001b[45;81H            # 2. Add unvisited neighbors to the stack.                         \u001b[46;81H            # Since we pop the stack, adding neighbors in reverse order        \u001b[47;81H            # (or processing the adjacency list in reverse) ensures that       \u001b[48;81H "]
[0.000, "o", "           # the neighbors are processed in the natural order defined by      \u001b[49;81Hthe graph's list.                                                              \u001b[50;81H            # This makes the traversal deterministic when the neighbors        \u001b[51;81Hlist order matters.                                                            \u001b[52;81H            neighbors = graph.get(current_node, [])                            \u001b[53;81H                                                                               \u001b[54;81H            # Iterate in reverse to maintain canonical traversal order         \u001b[55;81H(e.g., A -> B -> C)                                                            \u001b[56;81H            for neighbor in reversed(neighbors):                               \u001b[57;81H                if neighbor not in visited:                                    \u001b[58;81H                    stack.append(neighbor)                                     \u001b[59;81H                                                                               \u001b[60;81H    return visited                                                             \u001b[61;81H                                                                               \u001b[62;81H# --- Example Usage ---                                                        \u001b[63;81Hif __name__ == '__main__':                                                     \u001b[64;81H                                                                               \u001b[34h\u001b[?25h\u001b[24C"]
