[0.001, "o", "\u001b[?25l\u001b[1;81H                                                                               \u001b[2;81H    # Set to track visited nodes ensures O(1) lookup time and prevents         \u001b[3;81Hcycles from infinite loops.                                                    \u001b[4;81H    visited: Set[Any] = set()                                                  \u001b[5;81H                                                                               \u001b[6;81H    # Stack for iterative DFS traversal. Initialized with the start node.      \u001b[7;81H    stack: List[Any] = [start_node]                                            \u001b[8;81H                                                                               \u001b[9;81H    while stack:                                                               \u001b[10;81H        # Pop the current node to process                                      \u001b[11;81H        current_node: Any = stack.pop()                                        \u001b[12;81H                                                                               \u001b[13;81H        if current_node not in visited:                                        \u001b[14;81H            # 1. Process the node (e.g., print it, add it to results)          \u001b[15;81H            visited.add(current_node)                                          \u001b[16;81H                                                                               \u001b[17;81H            # 2. Add unvisited neighbors to the stack.                         \u001b[18;81H            # Since we pop the stack, adding neighbors in reverse order        \u001b[19;81H            # (or processing the adjacency list in reverse) ensures that       \u001b[20;81H            # the neighbors are processed in the natural order defined by      \u001b[21;81Hthe graph's list.                                                              \u001b[22;81H            # This makes the traversal deterministic when the neighbors        \u001b[23;81Hlist order matters.                                                            \u001b[24;81H            neighbors = graph.get(current_node, [])                            \u001b[25;81H                                                                               \u001b[26;81H            # Iterate in reverse to maintain canonical traversal order         \u001b[27;81H(e.g., A -> B -> C)                                                            \u001b[28;81H            for neighbor in reversed(neighbors):                               \u001b[29;81H                if neighbor not in visited:                                    \u001b[30;81H                    stack.append(neighbor)                                     \u001b[31;81H                                                                               \u001b[32;81H    return visited                                                             \u001b[33;81H                                                                               \u001b[34;81H# --- Example Usage ---                                                        \u001b[35;81Hif __name__ == '__main__':                                                     \u001b[36;81H    # Example 1: Simple Graph (Adjacency List)                                 \u001b[37;81H    graph1: Dict[str, List[str]] = {                                           \u001b[38;81H        \"A\": [\"B\", \"C\"],                                                       \u001b[39;81H        \"B\": [\"D\", \"E\"],                                                       \u001b[40;81H        \"C\": [\"F\"],                                                            \u001b[41;81H        \"D\": [\"E\"],                                                            \u001b[42;81H        \"E\": [\"F\"],                                                            \u001b[43;81H        \"F\": []                                                                \u001b[44;81H    }                                                                          \u001b[45;81H    start1 = \"A\"                                                               \u001b[46;81H    print(f\"--- Graph 1 DFS from {start1} ---\")                                \u001b[47;81H    visited1 = depth_first_search(graph1, start1)                              \u001b[48;81H "]
