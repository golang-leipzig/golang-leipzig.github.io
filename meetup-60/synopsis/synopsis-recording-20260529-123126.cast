[0.003, "o", "\u001b[?25l\u001b[1;79H\u001b[1K\u001b[38;5;245m\u001b[Hthe search.\u001b[39m\u001b[2;79H\u001b[1K\u001b[38;5;245m\r\n*(Self-Correction during implementation: Ensure the graph handles \u001b[39m             \u001b[38;5;245m\r\npotential unconnected components, although for simplicity, a single entry \u001b[39m     \u001b[38;5;245m\r\npoint `dfs(start_node)` is sufficient for the initial version.)*\u001b[39m               \u001b[6;79H\u001b[1K\u001b[38;5;245m\r\n9.  **Generating the final output (The resulting code block).**\u001b[39m                \u001b[8;79H\u001b[1K\u001b[38;5;245m\u001b[1m\r...done thinking.\u001b[m\u000f\u001b[9;79H\u001b[1K\n\u001b[1K\r```python\r\n# Graph representation using an adjacency dictionary                           \u001b[12;79H\u001b[1K\r# Key = Node, Value = List of neighbors\u001b[13;79H\u001b[1K\rgraph = {\u001b[14;79H\u001b[1K\r    'A': ['B', 'C'],\u001b[15;79H\u001b[1K\r    'B': ['D', 'E'],\u001b[16;79H\u001b[1K\r    'C': ['F'],\u001b[17;79H\u001b[1K\r    'D': ['F'],\r\n    'E': ['A', 'F'], # Note: Creating a cycle to show robustness               \u001b[19;79H\u001b[1K\r    'F': []\u001b[20;79H\u001b[1K\r}\u001b[21;79H\u001b[1K\n\u001b[1K\rdef depth_first_search(start_node):\u001b[23;79H\u001b[1K\r    \"\"\"\r\n    Performs Depth-First Search (DFS) starting from a given node.              \u001b[25;79H\u001b[1K\r    \r\n    DFS explores as far as possible along each branch before                   \u001b[27;79H\u001b[1K\rbacktracking.\u001b[28;79H\u001b[1K\r    \"\"\"\u001b[29;79H\u001b[1K\r    \r\n    # 1. visited set: This is crucial! It prevents us from going into          \r\n    #    an infinite loop if the graph contains cycles (e.g., A -> B ->        \u001b[32;79H\u001b[1K\rA).\u001b[33;79H\u001b[1K\r    visited = set()\u001b[34;79H\u001b[1K\r    \r\n    # The actual recursive helper function                                     \u001b[36;79H\u001b[1K\r    def dfs_recursive(node):\r\n        # Step 1: Check if we've already processed this node                   \u001b[38;79H\u001b[1K\r        if node in visited:\r\n            return # If visited, stop this path                                \u001b[40;79H\u001b[1K\r        \r\n        # Step 2: Process the current node (Mark it and print it)              \u001b[42;79H\u001b[1K\r        visited.add(node)\r\n        print(node, end=\" \") # Display the node being visited                  \u001b[44;79H\u001b[1K\r        \r\n        # Step 3: Explore neighbors (The 'Depth' part)                         \r\n        # For every neighbor of the current node, call the function            \u001b[47;79H\u001b[1K\rrecursively\u001b[48;79H\u001b[1K\r        for neighbor in graph[node]:\r\n            dfs_recursive(neighbor) # This call dives deeper into the          \u001b[50;79H\u001b[1K\rgraph\u001b[51;79H\u001b[1K\r            \u001b[52;79H\u001b[1K\r    # Start the search process\r\n    print(f\"Starting DFS from node {start_node}:\")                             \u001b[54;79H\u001b[1K\r    dfs_recursive(start_node)\u001b[55;79H\u001b[1K\n\u001b[1K\r# --- Execution ---\u001b[57;79H\u001b[1K\n\u001b[1K\r# Start the search from node 'A'\u001b[59;79H\u001b[1K\rdepth_first_search('A')\u001b[60;79H\u001b[1K\n\u001b[1K\rprint(\"\\n--- Test Case 2 ---\")\u001b[62;79H\u001b[1K\r# Start the search from node 'C'\u001b[63;79H\u001b[1K\rdepth_first_search('C')\u001b[64;79H\u001b[1K\u001b[34h\u001b[?25h\u001b[84C"]
[0.043, "o", "\u001b[?25l\u001b[1;81H    while stack:                                                               \u001b[2;81H        # Pop the current node to process                                      \u001b[3;81H        current_node: Any = stack.pop()                                        \u001b[4;81H                                                                               \u001b[5;81H        if current_node not in visited:                                        \u001b[6;81H            # 1. Process the node (e.g., print it, add it to results)          \u001b[7;81H            visited.add(current_node)                                          \u001b[8;81H                                                                               \u001b[9;81H            # 2. Add unvisited neighbors to the stack.                         \u001b[10;81H            # Since we pop the stack, adding neighbors in reverse order        \u001b[11;81H            # (or processing the adjacency list in reverse) ensures that       \u001b[12;81H            # the neighbors are processed in the natural order defined by      \u001b[13;81Hthe graph's list.                                                              \u001b[14;81H            # This makes the traversal deterministic when the neighbors        \u001b[15;81Hlist order matters.                                                            \u001b[16;81H            neighbors = graph.get(current_node, [])                            \u001b[17;81H                                                                               \u001b[18;81H            # Iterate in reverse to maintain canonical traversal order         \u001b[19;81H(e.g., A -> B -> C)                                                            \u001b[20;81H            for neighbor in reversed(neighbors):                               \u001b[21;81H                if neighbor not in visited:                                    \u001b[22;81H                    stack.append(neighbor)                                     \u001b[23;81H                                                                               \u001b[24;81H    return visited                                                             \u001b[25;81H                                                                               \u001b[26;81H# --- Example Usage ---                                                        \u001b[27;81Hif __name__ == '__main__':                                                     \u001b[28;81H    # Example 1: Simple Graph (Adjacency List)                                 \u001b[29;81H    graph1: Dict[str, List[str]] = {                                           \u001b[30;81H        \"A\": [\"B\", \"C\"],                                                       \u001b[31;81H        \"B\": [\"D\", \"E\"],                                                       \u001b[32;81H        \"C\": [\"F\"],                                                            \u001b[33;81H        \"D\": [\"E\"],                                                            \u001b[34;81H        \"E\": [\"F\"],                                                            \u001b[35;81H        \"F\": []                                                                \u001b[36;81H    }                                                                          \u001b[37;81H    start1 = \"A\"                                                               \u001b[38;81H    print(f\"--- Graph 1 DFS from {start1} ---\")                                \u001b[39;81H    visited1 = depth_first_search(graph1, start1)                              \u001b[40;81H    print(f\"Visited Nodes: {visited1}\") # Expected: {'A', 'B', 'D', 'E',       \u001b[41;81H'C', 'F'}                                                                      \u001b[42;81H                                                                               \u001b[43;81H    print(\"-\" * 20)                                                            \u001b[44;81H                                                                               \u001b[45;81H    # Example 2: Graph with Cycles and disconnected components                 \u001b[46;81H    graph2: Dict[int, List[int]] = {                                           \u001b[47;81H        1: [2, 3],                                                             \u001b[48;81H "]
[0.000, "o", "       2: [4],                                                                \u001b[49;81H        3: [5],                                                                \u001b[50;81H        4: [2, 6], # Cycle: 2 <-> 4                                            \u001b[51;81H        5: [6],                                                                \u001b[52;81H        6: []                                                                  \u001b[53;81H    }                                                                          \u001b[54;81H    start2 = 1                                                                 \u001b[55;81H    print(f\"--- Graph 2 DFS from {start2} ---\")                                \u001b[56;81H    visited2 = depth_first_search(graph2, start2)                              \u001b[57;81H    print(f\"Visited Nodes: {visited2}\") # Expected: {1, 2, 3, 4, 5, 6}         \u001b[58;81H                                                                               \u001b[59;81H    # Example 3: Handling Non-existent start node                              \u001b[60;81H    try:                                                                       \u001b[61;81H        depth_first_search(graph1, \"Z\")                                        \u001b[62;81H    except ValueError as e:                                                    \u001b[63;81H        print(\"-\" * 20)                                                        \u001b[64;81H                                                                               \u001b[34h\u001b[?25h\u001b[3C\r```\u001b[159C"]
