                                        \u001b[23;81H            for neighbor in reversed(neighbors):                               \u001b[24;81H                if neighbor not in visited:                                    \u001b[25;81H                    stack.append(neighbor)                                     \u001b[26;81H                                                                               \u001b[27;81H    return visited                                                             \u001b[28;81H                                                                               \u001b[29;81H# --- Example Usage ---                                                        \u001b[30;81Hif __name__ == '__main__':                                                     \u001b[31;81H    # Example 1: Simple Graph (Adjacency List)                                 \u001b[32;81H    graph1: Dict[str, List[str]] = {                                           \u001b[33;81H        \"A\": [\"B\", \"C\"],                                                       \u001b[34;81H        \"B\": [\"D\", \"E\"],                                                       \u001b[35;81H        \"C\": [\"F\"],                                                            \u001b[36;81H        \"D\": [\"E\"],                                                            \u001b[37;81H        \"E\": [\"F\"],                                                            \u001b[38;81H        \"F\": []                                                                \u001b[39;81H    }                                                                          \u001b[40;81H    start1 = \"A\"                                                               \u001b[41;81H    print(f\"--- Graph 1 DFS from {start1} ---\")                                \u001b[42;81H    visited1 = depth_first_search(graph1, start1)                              \u001b[43;81H    print(f\"Visited Nodes: {visited1}\") # Expected: {'A', 'B', 'D', 'E',   