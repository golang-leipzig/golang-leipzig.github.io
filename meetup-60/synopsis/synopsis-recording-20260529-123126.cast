1b[1K\n\u001b[1K\r```python\r\n# Graph representation using an adjacency dictionary                           \u001b[27;79H\u001b[1K\r# Key = Node, Value = List of neighbors\u001b[28;79H\u001b[1K\rgraph = {\u001b[29;79H\u001b[1K\r    'A': ['B', 'C'],\u001b[30;79H\u001b[1K\r    'B': ['D', 'E'],\u001b[31;79H\u001b[1K\r    'C': ['F'],\u001b[32;79H\u001b[1K\r    'D': ['F'],\r\n    'E': ['A', 'F'], # Note: Creating a cycle to show robustness               \u001b[34;79H\u001b[1K\r    'F': []\u001b[35;79H\u001b[1K\r}\u001b[36;79H\u001b[1K\n\u001b[1K\rdef depth_first_search(start_node):\u001b[38;79H\u001b[1K\r    \"\"\"\r\n    Performs Depth-First Search (DFS) starting from a given node.              \u001b[40;79H\u001b[1K\r    \r\n    DFS explores as far as possible along each branch before                   \u001b[42;79H\u001b[1K\rbacktracking.\u001b[43;79H\u001b[1K\r    \"\"\"\u001b[44;79H\u001b[1K\r    \r\n    # 1. visited set: This is crucial! It prevents us from going into          \r\n    #    an infinite loop if the graph contains cycles (e.g., A -> B ->        \u001b[47;79H\u001b[1K\rA).\u001b[48;79H\u001b[1K\r    visited = set()\u001b[49;79H\u001b[1K\r    \r\n    # The actual recursive helper function                                     \u001b[51;79H\u001b[1K\r    def dfs_recursive(node):\r\n        # Step 1: Check if we've already processed this node                   \u001b[53;79H\u001b[1K\r        if node in visited:\r\n            return # If visited, stop this path                                \u001b[55;79H\u001b[1K\r        \r\n        # Step 2: Process the current node (Mark it and print it)              \u001b[57;79H\u001b[1K\r        visited.add(node)\r\n        print(node, end=\" \") # Display the node being visited                  \u001b[59;79H\u001b[1K\r        \r\n        # Step 3: Explore neighbors (The 'Depth' part)                         \r\n        # For every neighbor of the current node, call the function            \u001b[62;79H\u001b[1K\rrecursively\u001b[63;79H\u001b[1K\r        for neighbor in graph[node]:\u001b[64;79H\u001b[1K\u001b[34h\u001b[?25h\u001b[84C"]
