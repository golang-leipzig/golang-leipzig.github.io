[0.005, "o", "\u001b[?25l\u001b[1;80H\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[2;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[3;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[4;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[5;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[6;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[7;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[8;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[9;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[10;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[11;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[12;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[13;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[14;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[15;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[16;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[17;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[18;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[19;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[20;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[21;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[22;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[23;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u000f\u001b[38;5;51m│\u001b[24;80H\u001b[m\u000f\u001b[38;5;238m│\u001b[79C\u001b[m\u00