visited = set()\u001b[39m\u001b[K\u001b[38;5;245m\u001b[25;161H    # Use a stack/list for explicit traversal if avoiding recursion depth \u001b[39m\u001b[K\u001b[38;5;245m\u001b[26;161Hlimit,\u001b[39m\u001b[K\u001b[38;5;245m\u001b[27;161H    # but recursion is more compact conceptually. Let's stick to \u001b[39m\u001b[K\u001b[38;5;245m\u001b[28;161Hrecursion.\u001b[39m\u001b[K\u001b[29;161H\u001b[K\u001b[38;5;245m\n    def explore(node):\u001b[39m\u001b[K\u001b[38;5;245m\u001b[31;161H        if node not in visited:\u001b[39m\u001b[K\u001b[38;5;245m\u001b[32;161H            print(node) # Action to perform on visiting\u001b[39m\u001b[K\u001b[38;5;245m\u001b[33;161H            visited.add(node)\u001b[39m\u001b[K\u001b[38;5;245m\u001b[34;161H            for neighbor in graph.get(node, []):\u001b[39m\u001b[K\u001b[38;5;245m\u001b[35;161H                explore(neighbor)\u001b[39m\u001b[K\u001b[36;161H\u001b[K\u001b[38;5;245m\n    explore(start)\u001b[39m\u001b[K\u001b[38;161H\u001b[K\u001b[38;5;245m\n# Example usage setup\u001b[39m\u001b[K\u001b[38;5;245m\u001b[40;161H# graph = { ... }\u001b[39m\u001b[K\u001b[38;5;245m\u001b[41;161H# dfs(graph, 'A')\u001b[39m\u001b[K\u001b[38;5;245m\u001b[42;161H```\u001b[39m\u001b[K\u001b[43;161H\u001b[K\u001b[38;5;245m\n(I will simplify the final output by making it a single self-contained \u001b[39m\u001b[K\u001b[38;5;245m\u001b[45;161Hset of functions/logic, demonstrating the core recursive pattern.)\u001b[39m\u001b[K\u001b[38;5;245m\u001b[1m\u001b[46;161H...done thinking.\u001b[m\u000f\u001b[K\u001b[47;161H\u001b[K\n```python\u001b[K\u001b[49;161Hdef dfs(graph, start_node):\u001b[K\u001b[50;161H    \"\"\"Performs Depth-First Search on a graph represented by an adjacency \u001b[K\u001b[51;161Hdictionary.\"\"\"\u001b[K\u001b[52;161H    visited = set()\u001b[K\u001b[53;161H\u001b[K\n    def explore(node):\u001b[K\u001b[55;161H        if node not in visited:\u001b[K\u001b[56;161H            # Action upon visiting the node (e.g., printing it)\u001b[K\u001b[57;161H            print(node)\u001b[K\u001b[58;161H            visited.add(node)\u001b[K\u001b[59;161H\u001b[K\n            # Recursively call DFS for all unvisited neighbors\u001b[K\u001b[61;161H            for neighbor in graph.get(node, []):\u001b[K\u001b[62;161H                explore(neighbor)\u001b[K\u001b[63;161H\u001b[K\n\u001b[K\u001b[34h\u001b[?25h"]
