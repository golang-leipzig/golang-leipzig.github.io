1b[29;79H\u001b[1K\r    'F': []\u001b[30;79H\u001b[1K\r}\u001b[31;79H\u001b[1K\n\u001b[1K\rdef depth_first_search(start_node):\u001b[33;79H\u001b[1K\r    \"\"\"\r\n    Performs Depth-First Search (DFS) starting from a given node.              \u001b[35;79H\u001b[1K\r    \r\n    DFS explores as far as possible along each branch before                   \u001b[37;79H\u001b[1K\rbacktracking.\u001b[38;79H\u001b[1K\r    \"\"\"\u001b[39;79H\u001b[1K\r    \r\n    # 1. visited set: This is crucial! It prevents us from going into          \r\n    #    an infinite loop if the graph contains cycles (e.g., A -> B ->        \u001b[42;79H\u001b[1K\rA).\u001b[43;79H\u001b[1K\r    visited = set()\u001b[44;79H\u001b[1K\r    \r\n    # The actual recursive helper function                                     \u001b[46;79H\u001b[1K\r    def dfs_recursive(node):\r\n        # Step 1: Check if we've already processed this node                   \u001b[48;79H\u001b[1K\r        if node in visited:\r\n            return # If visited, stop this path                                \u001b[50;79H\u001b[1K\r        \r\n        # Step 2: Process the current node (Mark it and print it)              \u001b[52;79H\u001b[1K\r        visited.add(node)\r\n        print(node, end=\" \") # Display the node being visited                  \u001b[54;79H\u001b[1K\r        \r\n        # Step 3: Explore neighbors (The 'Depth' part)                         \r\n        # For every neighbor of the current node, call the function            \u001b[57;79H\u001b[1K\rrecursively\u001b[58;79H\u001b[1K\r        for neighbor in graph[node]:\r\n            dfs_recursive(neighbor) # This call dives deeper into the          \u001b[60;79H\u001b[1K\rgraph\u001b[61;79H\u001b[1K\r            \u001b[62;79H\u001b[1K\r    # Start the search process\r\n    print(f\"Starting DFS from node {start_node}:\")                             \u001b[64;79H\u001b[1K\u001b[34h\u001b[?25h\u001b[84C"]
