                                        \u001b[23;81H    return visited                                                             \u001b[24;81H                                                                               \u001b[25;81H# --- Example Usage ---                                                        \u001b[26;81Hif __name__ == '__main__':                                                     \u001b[27;81H    # Example 1: Simple Graph (Adjacency List)                                 \u001b[28;81H    graph1: Dict[str, List[str]] = {                                           \u001b[29;81H        \"A\": [\"B\", \"C\"],                                                       \u001b[30;81H        \"B\": [\"D\", \"E\"],                                                       \u001b[31;81H        \"C\": [\"F\"],                                                            \u001b[32;81H        \"D\": [\"E\"],                                                            \u001b[33;81H        \"E\": [\"F\"],                                                            \u001b[34;81H        \"F\": []                                                                \u001b[35;81H    }                                                                          \u001b[36;81H    start1 = \"A\"                                                               \u001b[37;81H    print(f\"--- Graph 1 DFS from {start1} ---\")                                \u001b[38;81H    visited1 = depth_first_search(graph1, start1)                              \u001b[39;81H    print(f\"Visited Nodes: {visited1}\") # Expected: {'A', 'B', 'D', 'E',       \u001b[40;81H'C', 'F'}                                                                      \u001b[41;81H                                                                               \u001b[42;81H    print(\"-\" * 20)                                                            \u001b[43;81H                                                                               \u001b[44;81H    # Example 2: Graph with Cycles and disconnected components                 \u001b[45;81H    graph2: Dict[int, List[int]] = {                                           \u001b[46;81H        1: [2, 3],                                                             \u001b[47;81H        2: [4],                                                                \u001b[48;81H "]
[0.000, "o", "       3: [5],                                                                \u001b[49;81H        4: [2, 6], # Cycle: 2 <-> 4                                            \u001b[50;81H        5: [6],                                                                \u001b[51;81H        6: []                                                                  \u001b[52;81H    }                                                                          \u001b[53;81H    start2 = 1                                                                 \u001b[54;81H    print(f\"--- Graph 2 DFS from {start2} ---\")                                \u001b[55;81H    visited2 = depth_first_search(graph2, start2)                              \u001b[56;81H    print(f\"Visited Nodes: {visited2}\") # Expected: {1, 2, 3, 4, 5, 6}         \u001b[57;81H                                                                               \u001b[58;81H    # Example 3: Handling Non-existent start node                              \u001b[59;81H    try:                                                                       \u001b[60;81H        depth_first_search(graph1, \"Z\")                                        \u001b[61;81H    except ValueError as e:                                                    \u001b[62;81H        print(\"-\" * 20)                                                        \u001b[63;81H        print(f\"Error Caught: {e}\")                                            \u001b[64;81H                                                                               \u001b[34h\u001b[?25h\u001b[3C"]
