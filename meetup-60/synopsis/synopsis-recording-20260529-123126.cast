[0.001, "o", "\u001b[?25l\u001b[38;5;245m\u001b[1d        *   If `v` is not visited:\u001b[39m\u001b[K\u001b[38;5;245m\u001b[2;161H            *   Recursively call `dfs(graph, v, visited)`.\u001b[39m\u001b[K\u001b[3;161H\u001b[K\u001b[38;5;245m\n7.  **Refining for Compactness (Python):**\u001b[39m\u001b[K\u001b[38;5;245m\u001b[5;161H    *   I'll wrap it in a class or a self-contained function, but a \u001b[39m\u001b[K\u001b[38;5;245m\u001b[6;161Hfunction is simpler for a compact example.\u001b[39m\u001b[K\u001b[38;5;245m\u001b[7;161H    *   I need to handle the graph setup and calling mechanism cleanly.\u001b[39m\u001b[K\u001b[8;161H\u001b[K\u001b[38;5;245m\n*(Self-Correction/Refinement: To make it compact, I will use a function \u001b[39m\u001b[K\u001b[38;5;245m\u001b[10;161Hthat takes the graph and the starting node, and I will use a set for \u001b[39m\u001b[K\u001b[38;5;245m\u001b[11;161H`visited` checks.)*\u001b[39m\u001b[K\u001b[12;161H\u001b[K\u001b[38;5;245m\n8.  **Final Code Structure (Using recursion for maximum compactness):**\u001b[39m\u001b[K\u001b[14;161H\u001b[K\u001b[38;5;245m\n```python\u001b[39m\u001b[K\u001b[38;5;245m\u001b[16;161Hdef dfs(graph, start):\u001b[39m\u001b[K\u001b[38;5;245m\u001b[17;161H    visited = set()\u001b[39m\u001b[K\u001b[38;5;245m\u001b[18;161H    # Use a stack/list for explicit traversal if avoiding recursion depth \u001b[39m\u001b[K\u001b[38;5;245m\u001b[19;161Hlimit,\u001b[39m\u001b[K\u001b[38;5;245m\u001b[20;161H    # but recursion is more compact conceptually. Let's stick to \u001b[39m\u001b[K\u001b[38;5;245m\u001b[21;161Hrecursion.\u001b[39m\u001b[K\u001b[22;161H\u001b[K\u001b[38;5;245m\n    def explore(node):\u001b[39m\u001b[K\u001b[38;5;245m\u001b[24;161H        if node not in visited:\u001b[39m\u001b[K\u001b[38;5;245m\u001b[25;161H            print(node) # Action to perform on visiting\u001b[39m\u001b[K\u001b[38;5;245m\u001b[26;161H            visited.add(node)\u001b[39m\u001b[K\u001b[38;5;245m\u001b[27;161H            for neighbor in graph.get(node, []):\u001b[39m\u001b[K\u001b[38;5;245m\u001b[28;161H                explore(neighbor)\u001b[39m\u001b[K\u001b[29;161H\u001b[K\u001b[38;5;245m\n    explore(start)\u001b[39m\u001b[K\u001b[31;161H\u001b[K\u001b[38;5;245m\n# Example usage setup\u001b[39m\u001b[K\u001b[38;5;245m\u001b[33;161H# graph = { ... }\u001b[39m\u001b[K\u001b[38;5;245m\u001b[34;161H# dfs(graph, 'A')\u001b[39m\u001b[K\u001b[38;5;245m\u001b[35;161H```\u001b[39m\u001b[K\u001b[36;161H\u001b[K\u001b[38;5;245m\n(I will simplify the final output by making it a single self-contained \u001b[39m\u001b[K\u001b[38;5;245m\u001b[38;161Hset of functions/logic, demonstrating the core recursive pattern.)\u001b[39m\u001b[K\u001b[38;5;245m\u001b[1m\u001b[39;161H...done thinking.\u001b[m\u000f\u001b[K\u001b[40;161H\u001b[K\n```python\u001b[K\u001b[42;161Hdef dfs(graph, start_node):\u001b[K\u001b[43;161H    \"\"\"Performs Depth-First Search on a graph represented by an adjacency \u001b[K\u001b[44;161Hdictionary.\"\"\"\u001b[K\u001b[45;161H    visited = set()\u001b[K\u001b[46;161H\u001b[K\n    def explore(node):\u001b[K\u001b[48;161H        if node not in visited:\u001b[K\u001b[49;161H            # Action upon visiting the node (e.g., printing it)\u001b[K\u001b[50;161H            print(node)\u001b[K\u001b[51;161H            visited.add(node)\u001b[K\u001b[52;161H\u001b[K\n            # Recursively call DFS for all unvisited neighbors\u001b[K\u001b[54;161H            for neighbor in graph.get(node, []):\u001b[K\u001b[55;161H                explore(neighbor)\u001b[K\u001b[56;161H\u001b[K\n    explore(start_node)\u001b[K\u001b[58;161H\u001b[K\n# Example Usage:\u001b[K\u001b[60;161H# Graph defined as an adjacency dictionary\u001b[K\u001b[61;161Hgraph = {\u001b[K\u001b[62;161H    'A': ['B', 'C'],\u001b[K\u001b[63;161H    'B': ['D', 'E'],\u001b[K\u001b[64;161H\u001b[K\u001b[34h\u001b[?25h"]
[0.046, "o", "\u001b[?25l\u001b[1;81H                                                                               \u001b[2;81H    This implementation utilizes an explicit stack for iterative               \u001b[3;81Htraversal,                                                                     \u001b[4;81H    which is generally preferred over deep recursion for production code       \u001b[5;81H    to prevent potential StackOverflowErrors on large graphs.                  \u001b[6;81H                                                                               \u001b[7;81H    Args:                                                                      \u001b[8;81H        graph: A dictionary representing the graph, where keys are nodes       \u001b[9;81H               and values are lists of neighbors (adjacency list).             \u001b[10;81H        start_node: The node from which the traversal begins.                  \u001b[11;81H                                                                               \u001b[12;81H    Returns:                                                                   \u001b[13;81H        A set containing all unique nodes visited during the traversal.        \u001b[14;81H                                                                               \u001b[15;81H    Raises:                                                                    \u001b[16;81H        ValueError: If the start_node is not present in the graph.             \u001b[17;81H    \"\"\"                                                                        \u001b[18;81H    if start_node not in graph:                                                \u001b[19;81H        raise ValueError(f\"Start node '{start_node}' is not part of the        \u001b[20;81Hprovided graph.\")                                                              \u001b[21;81H                                                                               \u001b[22;81H    # Set to track visited nodes ensures O(1) lookup time and prevents         \u001b[23;81Hcycles from infinite loops.                                                    \u001b[24;81H    visited: Set[Any] = set()                                                  \u001b[25;81H                                                                               \u001b[26;81H    # Stack for iterative DFS traversal. Initialized with the start node.      \u001b[27;81H    stack: List[Any] = [start_node]                                            \u001b[28;81H                                                                               \u001b[29;81H    while stack:                                                               \u001b[30;81H        # Pop the current node to process                                      \u001b[31;81H        current_node: Any = stack.pop()                                        \u001b[32;81H                                                                               \u001b[33;81H        if current_node not in visited:                                        \u001b[34;81H            # 1. Process the node (e.g., print it, add it to results)          \u001b[35;81H            visited.add(current_node)                                          \u001b[36;81H                                                                               \u001b[37;81H            # 2. Add unvisited neighbors to the stack.                         \u001b[38;81H            # Since we pop the stack, adding neighbors in reverse order        \u001b[39;81H            # (or processing the adjacency list in reverse) ensures that       \u001b[40;81H            # the neighbors are processed in the natural order defined by      \u001b[41;81Hthe graph's list.                                                              \u001b[42;81H            # This makes the traversal deterministic when the neighbors        \u001b[43;81Hlist order matters.                                                            \u001b[44;81H            neighbors = graph.get(current_node, [])                            \u001b[45;81H                                                                               \u001b[46;81H            # Iterate in reverse to maintain canonical traversal order         \u001b[47;81H(e.g., A -> B -> C)                                                            \u001b[48;81H "]
[0.001, "o", "           for neighbor in reversed(neighbors):                               \u001b[49;81H                if neighbor not in visited:                                    \u001b[50;81H                    stack.append(neighbor)                                     \u001b[51;81H                                                                               \u001b[52;81H    return visited                                                             \u001b[53;81H                                                                               \u001b[54;81H# --- Example Usage ---                                                        \u001b[55;81Hif __name__ == '__main__':                                                     \u001b[56;81H    # Example 1: Simple Graph (Adjacency List)                                 \u001b[57;81H    graph1: Dict[str, List[str]] = {                                           \u001b[58;81H        \"A\": [\"B\", \"C\"],                                                       \u001b[59;81H        \"B\": [\"D\", \"E\"],                                                       \u001b[60;81H        \"C\": [\"F\"],                                                            \u001b[61;81H        \"D\": [\"E\"],                                                            \u001b[62;81H        \"E\": [\"F\"],                                                            \u001b[63;81H        \"F\": []                                                                \u001b[64;81H                                                                               \u001b[34h\u001b[?25h\u001b[C"]
