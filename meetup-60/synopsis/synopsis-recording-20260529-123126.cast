     A set containing all unique nodes visited during the traversal.        \u001b[23;81H                                                                               \u001b[24;81H    Raises:                                                                    \u001b[25;81H        ValueError: If the start_node is not present in the graph.             \u001b[26;81H    \"\"\"                                                                        \u001b[27;81H    if start_node not in graph:                                                \u001b[28;81H        raise ValueError(f\"Start node '{start_node}' is not part of the        \u001b[29;81Hprovided graph.\")                                                              \u001b[30;81H                                                                               \u001b[31;81H    # Set to track visited nodes ensures O(1) lookup time and prevents         \u001b[32;81Hcycles from infinite loops.                                                    \u001b[33;81H    visited: Set[Any] = set()                                                  \u001b[34;81H                                                                               \u001b[35;81H    # Stack for iterative DFS traversal. Initialized with the start node.      \u001b[36;81H    stack: List[Any] = [start_node]                                            \u001b[37;81H                                                                               \u001b[38;81H    while stack:                                                               \u001b[39;81H        # Pop the current node to process                                      \u001b[40;81H        current_node: Any = stack.pop()                                        \u001b[41;81H                                                                               \u001b[42;81H        if current_node not in visited:                                        \u001b[43;81H            # 1. Process the node (e.g., print it, add it to resul